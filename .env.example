# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the deployed frontend (used for CORS allow-list)
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (Story 1.3) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (Story 1.3) ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Role-based access control (Story 1.3 + Story 9.13 RBAC 3 roles) ──────────
# Roles válidos: family, contador, admin (matriz autoritativa: docs/rbac-3-roles.md).
# RBAC_ROLE_MAPPING (JSON) es la SoT actual; ALLOWED_USERS queda como fallback
# legacy y normaliza "owner" → "family" automáticamente para compat shim.
RBAC_ROLE_MAPPING={"ary@example.com":"admin","family-member@example.com":"family","contador@example.com":"contador"}
# Legacy fallback — usar RBAC_ROLE_MAPPING en deploys nuevos.
ALLOWED_USERS=family@example.com:family,contador@example.com:contador,ary@example.com:admin

# ── Google Sheets (existing pipeline) ─────────────────────────────────────────
# Path to the Google Service Account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=pipeline/config/serviceAccountKey.json
GOOGLE_SHEET_ID=your-google-sheet-id

# ── Laudus ERP (existing pipeline) ────────────────────────────────────────────
LAUDUS_USERNAME=your-laudus-username
LAUDUS_PASSWORD=your-laudus-password
LAUDUS_COMPANYVATID=your-company-vat-id

# ── Cloud Run (Story 1.5) ──────────────────────────────────────────────────────
# Backend Cloud Run service URL (set as FRONTEND env var at deploy time)
BACKEND_URL=https://your-backend-service-url.run.app

# ── Supabase (Story 4.0) ───────────────────────────────────────────────────────
# Use the service role key (not anon key) — bypasses row-level security
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Gemini (Story 9.5 — PDF upload + extraction) ──────────────────────────────
# API key from Google AI Studio (aistudio.google.com/apikey)
# Bound to a Google Cloud project — verify billing/quota habilitada en consola.
GEMINI_API_KEY=your-gemini-api-key
