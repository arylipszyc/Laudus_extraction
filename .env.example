# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the deployed frontend (used for CORS allow-list)
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (Story 1.3) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (Story 1.3) ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Role-based access control (Story 1.3) ─────────────────────────────────────
# Comma-separated list of email:role pairs (roles: owner, contador)
ALLOWED_USERS=owner@example.com:owner,contador@example.com:contador

# ── Google Sheets (existing pipeline) ─────────────────────────────────────────
# Path to the Google Service Account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=config/serviceAccountKey.json
GOOGLE_SHEET_ID=your-google-sheet-id

# ── Laudus ERP (existing pipeline) ────────────────────────────────────────────
LAUDUS_USERNAME=your-laudus-username
LAUDUS_PASSWORD=your-laudus-password
LAUDUS_COMPANYVATID=your-company-vat-id

# ── Cloud Run (Story 1.5) ──────────────────────────────────────────────────────
# Backend Cloud Run service URL (set as FRONTEND env var at deploy time)
BACKEND_URL=https://your-backend-service-url.run.app
